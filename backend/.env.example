# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gamified_pm
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT (REQUIRED — min 32 chars, generate with: openssl rand -hex 32) ───────
JWT_SECRET=change-me-to-a-random-256-bit-secret-in-production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── CORS (production: only your actual domain) ────────────────────────────────
# CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Email (optional — verification is disabled by default) ───────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
EMAIL_VERIFICATION_REQUIRED=false
FRONTEND_URL=http://localhost:5173

# ── File uploads ──────────────────────────────────────────────────────────────
FILE_UPLOAD_DIR=./uploads

# ── AI (optional — disabled by default) ──────────────────────────────────────
AI_ENABLED=false
AI_PROVIDER=ollama
AI_MODEL=llama3.2
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── Login protection ──────────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_DURATION_MINUTES=15

# ── Production only ───────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=prod
# DB_POOL_MAX=20
# DB_POOL_MIN=10
# REDIS_POOL_MAX=16
# REDIS_POOL_MIN=4
# LOG_FILE=/app/logs/application.log
# FILE_UPLOAD_DIR=/app/uploads
